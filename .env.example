# Supabase (optional: cloud sync for auth, portfolio, tracking and history)
SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_USER_ID=

# Private strategy service
# local: use bundled compatibility implementation
# auto: use API when URL/key are configured, otherwise local fallback
# remote: require private API and never fall back to local strategy code
WYCKOFF_STRATEGY_API_MODE=local
WYCKOFF_STRATEGY_API_URL=
WYCKOFF_STRATEGY_API_KEY=
WYCKOFF_STRATEGY_VERSION=private-v1
WYCKOFF_STRATEGY_API_TIMEOUT=30
WYCKOFF_STRATEGY_API_POLL_INTERVAL=2
WYCKOFF_STRATEGY_API_POLL_TIMEOUT=600

# Market data providers (optional in public app; private Strategy API can own these)
TICKFLOW_API_KEY=
TICKFLOW_TIMEOUT_SECONDS=12
TICKFLOW_MAX_RETRIES=3
TICKFLOW_RETRY_BACKOFF_SECONDS=1.5
TUSHARE_TOKEN=

# LLM providers
DEFAULT_LLM_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
OPENAI_API_KEY=
OPENAI_MODEL=
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=
ZHIPU_API_KEY=
ZHIPU_MODEL=
MINIMAX_API_KEY=
MINIMAX_MODEL=
QWEN_API_KEY=
QWEN_MODEL=
VOLCENGINE_API_KEY=
VOLCENGINE_MODEL=

# OpenAI-compatible low-cost model channel for summaries and formatting
EFFICIENCY_API_KEY=
EFFICIENCY_MODEL=
EFFICIENCY_BASE_URL=

# Notifications
FEISHU_WEBHOOK_URL=
TG_BOT_TOKEN=
TG_CHAT_ID=

# Local fallback portfolio state
MY_PORTFOLIO_STATE=

# Public app runtime switches
ALLOW_APPROX_TRADE_CALENDAR=0
ENFORCE_TARGET_TRADE_DATE=0
SPOT_SNAPSHOT_TTL_SECONDS=20
